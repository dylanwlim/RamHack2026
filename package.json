{
  "name": "pharmapath",
  "private": true,
  "scripts": {
    "build:medication-search-assets": "node scripts/build-medication-search-assets.mjs",
    "build": "npm run build:medication-search-assets && next build",
    "dev": "next dev",
    "start": "next start",
    "sync:medications": "node scripts/sync-medication-index.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run build:medication-search-assets && node --test tests/*.test.js",
    "preview": "npm run build:medication-search-assets && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "npm run build:medication-search-assets && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "npm run build:medication-search-assets && opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "clsx": "^2.1.1",
    "firebase": "^12.11.0",
    "framer-motion": "^12.4.10",
    "lucide-react": "^0.542.0",
    "next": "16.0.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.9.4",
    "stream-chain": "^3.4.0",
    "stream-json": "^1.9.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.9",
    "tw-animate-css": "^1.3.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.9",
    "@types/node": "^22.13.9",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "postcss": "8.5.6",
    "typescript": "~5.7.2",
    "wrangler": "^4.78.0"
  }
}
